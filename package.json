{
	"name": "@prleasing/utility",
	"description": "Вспомогательные функции, которые пригодятся в работе",
	"version": "1.2.0",
	"keywords": [
		"typescript",
		"service",
		"utility"
	],
	"main": "dist/index.cjs.js",
	"module": "dist/index.es.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"docs"
	],
	"repository": {
		"url": "https://github.com/prleasing/utility"
	},
	"homepage": "https://prleasing.github.io/utility",
	"license": "Apache-2.0",
	"maintainers": [
		"Yakin Nikita <taknepoidet@yandex.ru>"
	],
	"scripts": {
		"init": "git config core.hooksPath ./.hooks",
		"dev": "vite build --watch",
		"build": "tsc && vite build",
		"docs": "jsdoc -c jsdoc.json",
		"eslint": "eslint --fix .",
		"prettier": "prettier --ignore-unknown --write .",
		"beautifier": "npm run eslint && npm run prettier",
		"prepublishOnly": "npm run docs && npm run build"
	},
	"devDependencies": {
		"@taknepoidet-config/eslint-config": "^1.10.0",
		"@taknepoidet-config/prettier": "^1.10.0",
		"@vitejs/plugin-vue": "^3.0.1",
		"better-docs": "^2.7.2",
		"eslint": "^8.20.0",
		"jsdoc": "^3.6.11",
		"lint-staged": "^13.0.3",
		"prettier": "^2.7.1",
		"prettier-plugin-jsdoc": "^0.3.38",
		"rollup-plugin-dts": "^4.2.2",
		"vite": "^3.0.2",
		"vite-plugin-dts": "^1.4.0"
	},
	"dependencies": {
		"core-js": "^3.23.5"
	},
	"peerDependencies": {
		"vue": "^3.0.0"
	},
	"lint-staged": {
		"{src,test}/**/*.ts": "eslint"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
